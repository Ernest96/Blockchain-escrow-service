# Copy to .env and fill in. NEVER commit the .env file.
# Cardano Preview testnet only — do not reuse a mainnet mnemonic.

# Blockfrost project ID for Preview (https://blockfrost.io)
BLOCKFROST_PROJECT_ID=previewYOUR_PROJECT_ID

# Payer wallet — locks the funds, can refund after deadline.
PAYER_MNEMONIC="word1 word2 word3 ... word24"

# Provider wallet — claims the funds before deadline.
PROVIDER_MNEMONIC="word1 word2 word3 ... word24"
