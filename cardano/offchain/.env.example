# Blockfrost project ID
BLOCKFROST_PROJECT_ID=preprodYOUR_PROJECT_ID

# Admin / deployer wallet — owns the on-chain reference script UTxO.
# Used ONLY by `npm run publish-script` (one-time per deployment).
# Never participates in lock / claim / refund. Mirrors the deployer-key
# pattern used on Ethereum (separate from payer / provider). Needs ~25
# tADA: 20 locked as min-ada in the reference UTxO + ~1.5 tADA fee.
ADMIN_MNEMONIC="word1 word2 word3 ... word24"

# Payer wallet — locks the funds, can refund after deadline.
PAYER_MNEMONIC="word1 word2 word3 ... word24"

# Provider wallet — claims the funds before deadline.
PROVIDER_MNEMONIC="word1 word2 word3 ... word24"

# --- Action parameters (all optional; defaults shown) ---

# Lock parameters (used by `npm run lock`)
# LOCK_AMOUNT_ADA=5
# LOCK_DEADLINE_MIN=30
# LOCK_PROVIDER_PKH=<28-byte hex>          # default: derived from PROVIDER_MNEMONIC

# Claim / refund parameters (used by `npm run claim` / `npm run refund`)
# LOCK_TX_HASH=<paste from a previous lock output>     # required for claim/refund
