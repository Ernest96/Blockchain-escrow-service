# RPC endpoint (Infura / Alchemy / public). Sepolia chain ID = 11155111.
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Deployer key — used only by `npm run deploy:sepolia`
SEPOLIA_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Payer key — signs lock() and refund() in the action scripts.
PAYER_PRIVATE_KEY=0xYOUR_PAYER_PRIVATE_KEY

# Provider key 
PROVIDER_PRIVATE_KEY=0xYOUR_PROVIDER_PRIVATE_KEY

# Contract Address
ESCROW_ADDRESS=0x38e2a902699932FAf7F41F75D17DB782629d7899

# Deal
#DEAL_ID=0