{
  "name": "ethereum-escrow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "node": "hardhat node",
    "deploy:sepolia": "hardhat ignition deploy ignition/modules/Escrow.ts --network sepolia",
    "lock": "hardhat run scripts/sepolia/lock.ts --network sepolia",
    "claim": "hardhat run scripts/sepolia/claim.ts --network sepolia",
    "refund": "hardhat run scripts/sepolia/refund.ts --network sepolia",
    "wallets": "hardhat run scripts/show-wallets.ts",
    "storage-layout": "hardhat run scripts/print-storage-layout.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.0",
    "@types/chai": "^5.0.0",
    "@types/mocha": "^10.0.7",
    "@types/node": "^22.5.0",
    "chai": "^5.1.2",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.2",
    "hardhat": "^3.0.0",
    "mocha": "^11.0.0",
    "typescript": "^5.5.4"
  }
}
